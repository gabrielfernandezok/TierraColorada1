<?xml version="1.0" encoding="UTF-8"?>
<persistence version="3.2" xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_2.xsd">
  <persistence-unit name="Persistencia1" transaction-type="RESOURCE_LOCAL">
    <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

    <class>com.mycompany.tierracolorada1.modelos.Usuario</class>
    <class>com.mycompany.tierracolorada1.modelos.Productor</class>
    <class>com.mycompany.tierracolorada1.modelos.Lote</class>
    <class>com.mycompany.tierracolorada1.modelos.EtapaProceso</class>
    <class>com.mycompany.tierracolorada1.modelos.Vehiculo</class>
    <class>com.mycompany.tierracolorada1.modelos.Viaje</class>
    <class>com.mycompany.tierracolorada1.modelos.CamionPropio</class>
    <class>com.mycompany.tierracolorada1.modelos.FleteTercerizado</class>
    
    <properties>
      <property name="jakarta.persistence.schema-generation.database.action" value="create"/>
    </properties>
  </persistence-unit>
</persistence>
